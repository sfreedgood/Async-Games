{
  "name": "@async-games/async-games-backend",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--node-env=production"
          ],
          "transformers": [
            {
              "name": "@nestjs/swagger/plugin",
              "options": {
                "introspectComments": true
              }
            }
          ]
        },
        "configurations": {
          "development": {
            "args": [
              "--node-env=development"
            ]
          }
        }
      },
      "serve": {
        "executor": "nx:run-commands",
        "defaultConfiguration": "development",
        "options": {
          "command": "nx run @async-games/async-games-backend:serve-node:development",
          "envFile": ".env.development",
          "forwardAllArgs": true
        },
        "configurations": {
          "development": {
            "command": "nx run @async-games/async-games-backend:serve-node:development",
            "envFile": ".env.development"
          },
          "production": {
            "command": "nx run @async-games/async-games-backend:serve-node:production",
            "envFile": ".env"
          }
        }
      },
      "serve-node": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "@async-games/async-games-backend:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@async-games/async-games-backend:build:development"
          },
          "production": {
            "buildTarget": "@async-games/async-games-backend:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  },
  "dependencies": {
    "@nestjs/config": "^4.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "class-validator": "^0.14.2",
    "pg": "^8.13.1",
    "typeorm": "^0.3.20"
  }
}